# =============================================================================
# INPUT RAILS
# =============================================================================

# Rail 1 & 3: PII Detection and Masking (runs first - before LLM sees the query)
define flow check pii and mask input
  $pii_result = execute check_pii_input
  if $pii_result.has_pii
    $user_message = $pii_result.sanitized_message

# Rail 2, 4, 5: LLM-based checks — jailbreak, domain control, regulatory, sensitive query
define flow self check input
  $allowed = execute self_check_input
  if not $allowed
    bot refuse to respond
    stop

# =============================================================================
# OUTPUT RAILS
# =============================================================================

# Rail 5 (output): Sentiment & toxicity filter via LLM
define flow self check output
  $allowed = execute self_check_output
  if not $allowed
    bot refuse to respond
    stop

# Rails 1, 2, 3, 4, 6 (output): Python-based post-processing
define flow check output quality
  $result = execute process_output_quality
  if $result.modified
    $bot_message = $result.processed_response

# =============================================================================
# BOT MESSAGES
# =============================================================================

define bot refuse to respond
  "I'm sorry, I'm unable to assist with that request. I'm IntelliFinance — a financial information assistant. Please ask finance-related questions and avoid sharing sensitive personal data. For complex decisions, consult a licensed financial advisor."
